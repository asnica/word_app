<header class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container">
    <%= link_to "Word App", root_path, class: "navbar-brand" %>

    <div class="navbar-nav ms-auto">
      <ul class="navbar-nav align-items-lg-center">
        <li class="nav-item"><%= link_to "単語タグマスタ", tags_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "単語マスタ", words_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "問題集", "#", class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "ランキング", "#", class: "nav-link" %></li>

        <% if current_user %>
          <% # 1. ログイン状態の表示 %>
          <li class="nav-item ms-lg-3">
            <span class="nav-link disabled text-light opacity-75">
              <i class="bi bi-person"></i> <%= current_user.name %>様
            </span>
          </li>
          <li class="nav-item">
            <%= link_to "ログアウト", logout_path, 
                        data: { "turbo-method": :delete, "turbo-confirm": "ログアウトしますか？" }, 
                        class: "nav-link text-warning" %>
          </li>
        <% else %>
          <% # 2. 未ログイン状態の表示 %>
          <li class="nav-item ms-lg-3">
            <%= link_to "ログイン", login_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "新規登録", signup_path, class: "btn btn-primary btn-sm ms-lg-2" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</header>