<header class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container">
    <% # アプリケーションロゴ %>
    <%= link_to "Word App", root_path, class: "navbar-brand" %>

    <div class="navbar-nav ms-auto">
      <% # 共通メニュー項目 %>
      <ul class="navbar-nav">
        <li class="nav-item"><%= link_to "単語検索", "#", class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "問題集", "#", class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "ランキング", "#", class: "nav-link" %></li>
        
        <% # ログイン状態によるメニュー表示 %>
        <% if logged_in? %>
          <li class="nav-item"><%= link_to "ログアウト", logout_path, data: { "turbo-method": :delete }, class: "nav-link " %></li>
        <% else %>
          <li class="nav-item"><%= link_to "ログイン", login_path, class: "nav-link #{'active fw-bold' if current_page?(login_path)}" %></li>
        <% end %>
      </ul>
    </div>
  </div>
</header>