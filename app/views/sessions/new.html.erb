<% # ログイン画面 %>
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm mt-5">
      <div class="card-header bg-primary text-white text-center py-3">
        <h3 class="mb-0 fw-bold">ログイン</h3>
      </div>
      <div class="card-body p-4">
        <% # scope: :session -> モデルオブジェクトがないため、名前を :sessionにする %>
        <%= form_with scope: :session, url: login_path, local: true do |f| %>

        <div class="mb-3">
          <%= f.label :email, "メールアドレス", class: "form-label fw-bold" %>
          <%= f.email_field :email, class: "form-control", placeholder: "example@test.com" %>
        </div>

        <div class="mb-4">
          <%= f.label :password, "パスワード", class: "form-label fw-bold" %>
          <%= f.password_field :password, class: "form-control", placeholder: "パスワードを入力してください" %>
        </div>

        <div class="d-grid">
          <%= f.submit "ログイン", class: "btn btn-primary btn-lg" %>
        </div>

        <% end %>
      </div>
      <div class="card-footer text-center py-3 bg-light">
        <p class="mb-0 text-muted">
          アカウントをお持ちでないですか？ 
          <%= link_to "新規登録はこちら", signup_path, class: "text-primary fw-bold text-decoration-none" %>
        </p>
      </div>
    </div>
  </div>
</div>