<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
          <div>
            <h2 class="mb-0 fs-4"><%= @word.name %></h2>
            <div class="small mt-1 opacity-75">
              <i class="bi bi-person-circle"></i> 投稿者: <%= @word.user.name %>
            </div>
          </div>
          <%= link_to '一覧に戻る', words_path, class: 'btn btn-outline-light btn-sm' %>
        </div>
        
        <div class="card-body p-4">
          <% if @word.image.attached? %>
            <div class="text-center mb-4">
              <%= image_tag @word.image, class: "img-fluid rounded shadow-sm", style: "max-height: 300px;" %>
            </div>
          <% end %>
          
          <h5 class="text-muted small fw-bold">意味</h5>
          <p class="lead border-bottom pb-3"><%= @word.meaning %></p>

          <h5 class="text-muted small fw-bold">類義語</h5>
          <div class="mb-4">
            <% if @word.synonym.present? %>
              <% @word.synonym.split(',').each do |s| %>
                <% linked_word = Word.find_by(name: s.strip) %>
                <% if linked_word %>
                  <%= link_to s.strip, word_path(linked_word), class: 'badge rounded-pill bg-success text-decoration-none me-1' %>
                <% else %>
                  <span class="badge rounded-pill bg-secondary me-1"><%= s.strip %></span>
                <% end %>
              <% end %>
            <% else %>
              <p class="text-muted small">登録されていません</p>
            <% end %>
          </div>

          <h5 class="text-muted small fw-bold">タグ</h5>
          <div class="mb-4 flex-wrap d-flex gap-1">
            <% if @word.tags.any? %>
              <% @word.tags.each do |tag| %>
                <span class="badge bg-info text-dark text-decoration-none"><%= tag.name %></span>
              <% end %>
            <% else %>
              <span class="text-muted small">タグなし</span>
            <% end %>
          </div>

          <h5 class="text-muted small fw-bold">メモ</h5>
          <p class="bg-light p-3 rounded mb-0"><%= @word.note.presence || "メモはありません" %></p>
        </div>
        
        <% if @word.user == current_user %>
          <div class="card-footer text-end bg-white border-top-0 p-4">
            <%= link_to '編集', edit_word_path(@word), class: 'btn btn-outline-primary me-2' %>
            <%= link_to '削除', word_path(@word), data: { "turbo-method": :delete, "turbo-confirm": "本当に削除しますか？" }, class: 'btn btn-outline-danger' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>