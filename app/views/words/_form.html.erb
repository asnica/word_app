<%= form_with model: word, local: true do |f| %>
  <% # エラーメッセージ %>
  <% if word.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% word.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "単語", class: "form-label fw-bold" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :meaning, "意味", class: "form-label fw-bold" %>
    <%= f.text_field :meaning, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :synonym, "類義語", class: "form-label fw-bold" %>
    <%= f.select :synonym, options_for_select(@word.synonym.to_s.split(','), @word.synonym.to_s.split(',')), {}, 
        { 
          multiple: true, 
          class: "form-control", 
          data: { 
            controller: "select", 
            "select-create-value": "true", 
            "select-placeholder-value": "類義語を入力してEnter..." 
          } 
        } 
    %>
  </div>

  <div class="mb-3">
    <%= f.label :tag_ids, "タグ選択", class: "form-label fw-bold" %>
    <%= f.collection_select :tag_ids, Tag.all, :id, :name, {}, 
        { 
          multiple: true, 
          class: "form-control", 
          data: { controller: "select",
          "select-create-value": "false",
          "select-placeholder-value": "タグを検索..."
          } 
        } 
    %>
    <div class="form-text">キーワードを入力してタグを検索できます。</div>
  </div>

  <div class="mb-4">
    <%= f.label :note, "メモ", class: "form-label fw-bold" %>
    <%= f.text_area :note, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-3" data-controller="image-preview">
    <%= f.label :image, "画像添付", class: "form-label fw-bold" %>

    <div class="mb-2 d-flex align-items-end gap-3">
      <% if f.object.image.attached? && f.object.image.persisted? %>
        <%= image_tag f.object.image, 
                      data: { image_preview_target: "preview" }, 
                      class: "rounded shadow-sm border", 
                      style: "width: 100px; height: 100px; object-fit: cover;" %>
      <% else %>
        <img data-image-preview-target="preview" 
            src=""
            class="d-none rounded shadow-sm border" 
            style="width: 100px; height: 100px; object-fit: cover;">
      <% end %>

      <button type="button" 
              data-image-preview-target="cancelButton" 
              data-action="click->image-preview#reset" 
              class="btn btn-sm btn-outline-secondary d-none">
        選択を解除
      </button>
    </div>

    <% if f.object.image.attached? && f.object.image.persisted? %>
      <div class="form-check mb-2">
        <%= f.check_box :remove_image, class: "form-check-input" %>
        <%= f.label :remove_image, "現在の画像を削除する", class: "form-check-label small text-danger" %>
      </div>
    <% end %>

    <%= f.file_field :image, 
                    class: "form-control", 
                    accept: 'image/jpg,image/jpeg,image/png,image/gif',
                    data: { 
                      image_preview_target: "input", 
                      action: "change->image-preview#preview" 
                    } %>
    
    <div class="form-text">jpg, png, gif形式の画像を選択してください。</div>
  </div>
  
  <div class="d-grid">
    <%= f.submit "保存する", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>