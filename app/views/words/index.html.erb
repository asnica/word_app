<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">単語一覧</h2>
    <%= link_to "新規単語登録", new_word_path, class: "btn btn-success" %>
  </div>

  <%= form_with url: words_path, method: :get, local: true, class: "mb-4" do |f| %>
    <div class="input-group shadow-sm">
      <%= f.text_field :query, value: params[:query], class: "form-control", placeholder: "単語名で検索（曖昧検索）" %>
      <%= f.submit "検索", class: "btn btn-primary" %>
      <% if params[:query].present? %>
        <%= link_to "クリア", words_path, class: "btn btn-outline-secondary" %>
      <% end %>
    </div>
  <% end %>

  <div class="row g-3">
    <% if @words.any? %>
      <% @words.each do |word| %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm border-0 bg-light">
            <div class="card-body">
              
              <div class="d-flex align-items-center mb-3">
                <% if word.image.attached? %>
                  <%= image_tag word.image, class: "rounded me-3 shadow-sm", style: "width: 60px; height: 60px; object-fit: cover;" %>
                <% else %>
                  <div class="bg-secondary bg-opacity-25 rounded me-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-image text-muted"></i>
                  </div>
                <% end %>

                <div class="ms-1">
                  <h5 class="card-title fw-bold mb-0"><%= word.name %></h5>
                </div>
              </div>
                
              <div class="d-flex flex-wrap gap-1 mb-2">
                <% if word.tags.any? %>
                  <% word.tags.each do |tag| %>
                    <span class="badge bg-info text-dark"><%= tag.name %></span>
                  <% end %>
                <% else %>
                  <span class="badge bg-secondary">タグなし</span>
                <% end %>
              </div>

              <div class="text-muted mb-3" style="font-size: 0.8rem;">
                <i class="bi bi-person"></i> 投稿者: <%= word.user.name %>
              </div>

              <hr>
              
              <p class="card-text mb-1 text-secondary" style="font-size: 0.9rem;">
                <strong>意味：</strong><%= word.meaning %>
              </p>
              
            </div>
            
            <div class="card-footer bg-transparent border-0 text-end pb-3">
              <%= link_to "詳細", word_path(word), class: "btn btn-sm btn-link text-decoration-none" %>
              
              <% if word.user == current_user %>
                <%= link_to "編集", edit_word_path(word), class: "btn btn-sm btn-outline-primary" %>
                <%= link_to "削除", word_path(word), data: { "turbo-method": :delete, "turbo-confirm": "本当に削除しますか？" }, class: "btn btn-sm btn-outline-danger" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12 text-center py-5">
        <p class="text-muted">登録された単語がありません。</p>
        <%= link_to "最初の単語を登録する", new_word_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>