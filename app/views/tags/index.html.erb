<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">単語タグマスタ</h2>
    <%= link_to "メニューへ戻る", root_path, class: "btn btn-outline-secondary" %>
  </div>

  <% if @user.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card mb-4 shadow-sm border-primary">
    <div class="card-header bg-primary text-white fw-bold">新規タグ一括登録</div>
    <div class="card-body">
      <%= form_with model: @user, url: update_tags_tags_path, method: :patch, local: true do |f| %>
        <div class="links mb-4">
          <%= link_to_add_nested f, :tags, "#tags-form",
                                 link_text: "+ タグを追加",
                                 link_classes: "btn btn-sm btn-secondary",
                                 partial_form_variable: :form %>
        </div>
        
        <div id="tags-form">
          <%= f.fields_for :tags do |tag_f| %>
            <% if tag_f.object.new_record? %>
              <%= render 'tag_fields', form: tag_f %>
            <% end %>
          <% end %>
        </div>
        
        <div class="text-end mt-3">
          <%= f.submit "まとめて保存", class: "btn btn-success" %>
        </div>
      <% end %>
    </div>
  </div>

  <% # 検索セクション %>
  <%= form_with url: tags_path, method: :get, local: true, class: "mb-4" do |f| %>
    <div class="input-group">
      <%= f.text_field :query, value: params[:query], class: "form-control", placeholder: "タグ名で検索（曖昧検索）" %>
      <%= f.submit "検索", class: "btn btn-primary" %>
    </div>
  <% end %>

  <% # 一覧テーブル %>
  <div class="table-responsive">
    <table class="table table-hover align-middle bg-white border">
      <thead class="table-light">
        <tr>
          <th>タグ名</th>
          <th class="text-end">操作</th>
        </tr>
      </thead>
      <tbody>
        <% @tags.each do |tag| %>
          <tr>
            <td class="fw-bold"><%= tag.name %></td>
            <td class="text-end">
              <% is_mine = (tag.user == current_user) %>

              <% if is_mine %>
                <%= link_to "編集", edit_tag_path(tag), class: "btn btn-sm btn-outline-primary me-1" %>
                <%= link_to "削除", tag_path(tag), data: { "turbo-method": :delete, "turbo-confirm": "本当に削除しますか？" }, class: "btn btn-sm btn-outline-danger" %>
              <% else %>
                <span class="d-inline-block" tabindex="0" data-bs-toggle="tooltip" data-bs-title="作成者のみ編集・削除可能です。">
                  <button class="btn btn-sm btn-outline-secondary me-1" disabled style="pointer-events: none;">編集</button>
                  <button class="btn btn-sm btn-outline-secondary" disabled style="pointer-events: none;">削除</button>
                </span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>